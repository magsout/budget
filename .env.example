# Firebase Web app config — PUBLIC by design (safe in the bundle).
# Copy to .env.local (or .env) for local dev; in CI these come from GitHub Actions secrets.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Fixed e-mail of the single shared account. NOT sensitive (it is just an identifier).
# The PASSWORD is typed by the user at login and is never stored here or in the bundle.
VITE_FIREBASE_ACCOUNT_EMAIL=

# Optional: base path override for Vite (defaults to /budget/). Use "/" for a custom domain.
# VITE_BASE=/budget/
