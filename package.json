    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "jsdom": "^29.0.0",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "sharp": "^0.35.3",
    "typescript": "^5.7.0",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.0"
  }
